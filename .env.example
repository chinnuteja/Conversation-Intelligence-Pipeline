# Azure OpenAI (Chat Completions + json_schema)
OAI_BASE_LLM=https://your-resource.openai.azure.com/
OAI_KEY_LLM=your-api-key-here
OAI_VERSION=2024-12-01-preview

# Optional: json (default) or mongodb
DATA_SOURCE=json
MONGO_URI=mongodb://localhost:27017
MONGO_DB=helio_intern

# Optional
LOG_LEVEL=INFO
MAX_CONCURRENT_EVALS=20
CLUSTER_LABEL_MERGE_THRESHOLD=0.65
CLUSTER_CONVERSATION_OVERLAP_THRESHOLD=0.50
